client
dev tun
proto udp
remote ip-address-of-server 1194
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
cipher AES-256-CBC
auth SHA256
key-direction 1
verb 3
redirect-gateway def1
dhcp-option DNS 8.8.8.8

<ca>
# Paste the content of the ca.crt here
</ca>

<cert>
# Paste the content of the client1.crt here
</cert>

<key>
# Paste the content of the client1.key here
</key>

<tls-auth>
# Paste the content of the ta.key here
</tls-auth>